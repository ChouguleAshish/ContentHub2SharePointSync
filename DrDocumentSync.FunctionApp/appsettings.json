{
  "SyncOptions": {
    "Schedule": "0 0 2 * * 0",
    "BatchSize": 200,
    "DegreeOfParallelism": 8,
    "UseFileHashForIdempotency": true
  },
  "SitecoreOptions": {
    "BaseUrl": "https://your-contenthub.example.com/api",
    "AssetEndpoint": "/entities/query",
    "PageSize": 200,
    "TimeoutSeconds": 120,
    "ProductFilter": ["DR Product A"],
    "ProductFamilyFilter": ["Family A"],
    "ProductCategoryFilter": ["Category A"]
  },
  "SharePointOptions": {
    "TenantId": "00000000-0000-0000-0000-000000000000",
    "SiteId": "your-site-id",
    "DriveId": "your-document-library-drive-id",
    "RootFolder": "DR-Service-Documents"
  },
  "StateStoreOptions": {
    "StorageAccountUrl": "https://<account>.table.core.windows.net",
    "TableName": "DrSyncState",
    "PartitionKey": "DrDocumentSync",
    "RowKey": "LastRun"
  },
  "KeyVault": {
    "VaultUri": "https://your-keyvault.vault.azure.net/"
  },
  "SitecoreSecrets": {
    "ClientIdSecretName": "sitecore-client-id",
    "ClientSecretSecretName": "sitecore-client-secret"
  }
}
